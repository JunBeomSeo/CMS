<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>
<meta charset="UTF-8">
<title>맑은준범 - 게시글 상세/수정</title>
<style>
/* 전체 초기화 */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: 'Arial', sans-serif;
    background-color: #f4f5f7;
    min-height: 100vh;
    color: #333;
}

/* 상단 헤더 */
.header {
    width: 100%;
    background-color: #ffffff;
    padding: 15px 50px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
}

.header h1 {
    font-size: 24px;
    font-weight: 600;
}

/* 로그인/회원가입 버튼 */
.header .auth-btns a {
    margin-left: 12px;
    padding: 8px 18px;
    border-radius: 6px;
    text-decoration: none;
    font-weight: 500;
    color: #fff;
    font-size: 14px;
    transition: 0.3s;
}

.header .auth-btns a.login {
    background-color: #495057;
}

.header .auth-btns a.signup {
    background-color: #6c757d;
}

.header .auth-btns a.logout-btn {
    background-color: #f03e3e;
}

.header .auth-btns a:hover {
    opacity: 0.85;
}

/* 컨테이너 */
.container {
    width: 90%;
    max-width: 900px;
    margin: 40px auto;
    background-color: #fff;
    padding: 30px;
    border-radius: 12px;
    box-shadow: 0 5px 25px rgba(0,0,0,0.05);
}

/* 글 제목 */
.detail-title {
    font-size: 26px;
    font-weight: 600;
    margin-bottom: 15px;
    width: 100%;
    padding: 8px;
    border-radius: 6px;
    border: 1px solid #ddd;
    font-family: inherit;
}

/* 작성자, 작성일, 조회수 */
.detail-meta {
    font-size: 14px;
    color: #495057;
    margin-bottom: 30px;
}

.detail-meta span {
    margin-right: 20px;
}

/* 글 내용 */
.detail-content {
    width: 100%;
    min-height: 200px;
    resize: vertical;
}

/* 버튼 그룹 */
.btn-group {
    margin-top: 30px;
}

.btn-group a, .btn-group button {
    display: inline-block;
    margin-right: 10px;
    padding: 10px 25px;
    border-radius: 6px;
    text-decoration: none;
    font-weight: 500;
    color: #fff;
    transition: 0.3s;
    border: none;
    cursor: pointer;
    font-size: 14px;
}

.btn-back {
    background-color: #495057;
}

.btn-save {
    background-color: #1c7ed6;
}

.btn-delete {
    background-color: #f03e3e;
}

.btn-group a:hover, .btn-group button:hover {
    opacity: 0.85;
}
</style>
</head>
<body>

<!-- 상단 헤더 -->
<div class="header">
    <h1>맑은준범</h1>
    <div class="auth-btns">
        <div th:if="${session.id == null}">
            <a href="/loginPage" class="login">로그인</a>
            <a href="/signupPage" class="signup">회원가입</a>
        </div>
        <div th:if="${session.id != null}">
            <span class="welcome">
                환영합니다,
                <strong>
                    <span th:if="${session.role == 'ADMIN'}">관리자 </span>
                    <span th:text="${session.username}"></span>님!
                </strong>
            </span>
            <a href="/logout" class="logout-btn">로그아웃</a>
        </div>
    </div>
</div>

<!-- 상세 컨테이너 -->
<div class="container">
    <!-- 제목 수정 가능 -->
    <input type="text" class="detail-title" th:value="${board.title}" id="boardTitle">

    <div class="detail-meta">
        <span>작성자: <strong th:text="${board.writer}"></strong></span>
        <span>작성일: <strong th:text="${board.writedate.substring(0, 10)}"></strong></span>
        <span>조회수: <strong th:text="${board.readnum}"></strong></span>
    </div>

    <!-- 내용 수정 가능 -->
    <textarea class="detail-content" id="boardContent" th:text="${board.content}"></textarea>

    <!-- 버튼 그룹 -->
    <div class="btn-group">
        <a href="/boardList" class="btn-back">목록으로 돌아가기</a>
        <button class="btn-save" th:onclick="'saveBoard(' + ${board.board_idx} + ')'" >저장하기</button>
    </div>
</div>

<script>
var xhr;
function getXHR(){
	if(window.ActiveXObject){
		return new ActiveXObject('Msxml2.XMLHTTP');
	}else if(window.XMLHttpRequest){
		return new XMLHttpRequest();
	}else{
		return null;
	}
}
// 게시글 저장 함수
function saveBoard(boardIdx) {
    const title = document.getElementById('boardTitle').value.trim();
    const content = document.getElementById('boardContent').innerText.trim();
    const idx = boardIdx;

    if (!title || !content) {
        alert('제목과 내용을 모두 입력해주세요.');
        return;
    }
    
    var data = 'boardIdx=' + idx + '&title=' + encodeURIComponent(title) + '&content=' + encodeURIComponent(content);
    
    xhr = getXHR();
    xhr.onreadystatechange=saveBoardResult;
    xhr.open('PUT', '/api/board/update', true);
    xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
    xhr.send(data);
}
function saveBoardResult(){
	if(xhr.readyState == 4){
		
		var data = xhr.responseText;
		
		if(xhr.status == 200){
			alert(data);
			window.location.href='/boardList';
		}else{
			alert(data);
		}
	}
}
</script>

</body>
</html>
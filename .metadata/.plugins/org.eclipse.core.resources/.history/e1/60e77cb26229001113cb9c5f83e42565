<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>
<meta charset="UTF-8">
<title>맑은준범 - 게시글 상세</title>
<style>
/* 전체 초기화 */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: 'Arial', sans-serif;
    background-color: #f4f5f7;
    min-height: 100vh;
    color: #333;
}

/* 상단 헤더 */
.header {
    width: 100%;
    background-color: #ffffff;
    padding: 15px 50px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
}

.header h1 {
    font-size: 24px;
    font-weight: 600;
}

/* 로그인/회원가입 버튼 */
.header .auth-btns a {
    margin-left: 12px;
    padding: 8px 18px;
    border-radius: 6px;
    text-decoration: none;
    font-weight: 500;
    color: #fff;
    font-size: 14px;
    transition: 0.3s;
}

.header .auth-btns a.login {
    background-color: #495057;
}

.header .auth-btns a.signup {
    background-color: #6c757d;
}

.header .auth-btns a:hover {
    opacity: 0.85;
}

/* 컨테이너 */
.container {
    width: 90%;
    max-width: 900px;
    margin: 40px auto;
    background-color: #fff;
    padding: 30px;
    border-radius: 12px;
    box-shadow: 0 5px 25px rgba(0,0,0,0.05);
}

/* 글 제목 */
.detail-title {
    font-size: 26px;
    font-weight: 600;
    margin-bottom: 15px;
}

/* 작성자, 작성일, 조회수 */
.detail-meta {
    font-size: 14px;
    color: #495057;
    margin-bottom: 30px;
}

.detail-meta span {
    margin-right: 20px;
}

/* 글 내용 */
.detail-content {
    font-size: 16px;
    line-height: 1.7;
    color: #333;
    white-space: pre-wrap; /* 줄바꿈 유지 */
}

/* 돌아가기 버튼 */
.back-btn {
    display: inline-block;
    margin-top: 30px;
    padding: 10px 25px;
    background-color: #495057;
    color: #fff;
    text-decoration: none;
    border-radius: 6px;
    font-weight: 500;
    transition: 0.3s;
}

.back-btn:hover {
    opacity: 0.85;
}
</style>
</head>
<body>

<!-- 상단 헤더 -->
<div class="header">
    <h1>맑은준범</h1>
    <div class="auth-btns">
        <div th:if="${session.id == null}">
            <a href="/loginPage" class="login">로그인</a>
            <a href="/signupPage" class="signup">회원가입</a>
        </div>
        <div th:if="${session.id != null}">
            <span class="welcome">환영합니다, <strong th:text="${session.username}">사용자</strong>님!</span>
            <a href="/logout" class="logout-btn">로그아웃</a>
        </div>
    </div>
</div>

<!-- 상세 컨테이너 -->
<div class="container">
    <h2 class="detail-title" th:text="${board.title}">게시글 제목</h2>
    
    <div class="detail-meta">
        <span>작성자: <strong th:text="${board.writer}">작성자</strong></span>
        <span>작성일: <strong th:text="${board.writedate.substring(0, 10)}">2026-03-27</strong></span>
        <span>조회수: <strong th:text="${board.readnum}">0</strong></span>
    </div>
    
    <div class="detail-content" th:text="${board.content}">
        게시글 내용
    </div>
    
    <a href="/boardList" class="back-btn">목록으로 돌아가기</a>
</div>

</body>
</html>
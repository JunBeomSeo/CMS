<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>
<meta charset="UTF-8">
<title>맑은준범 - 회원가입</title>
<style>
/* 초기화 */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: 'Arial', sans-serif;
    background-color: #f4f5f7;
    min-height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
}

/* 폼 컨테이너 */
.signup-container {
    width: 100%;
    max-width: 450px;
    background-color: #fff;
    padding: 40px 30px;
    border-radius: 12px;
    box-shadow: 0 5px 25px rgba(0,0,0,0.08);
}

/* 폼 제목 */
.signup-container h2 {
    font-size: 24px;
    margin-bottom: 25px;
    text-align: center;
    color: #333;
}

/* 입력 필드 */
.signup-container input[type="text"],
.signup-container input[type="password"] {
    width: 100%;
    padding: 12px 15px;
    margin-bottom: 15px;
    border: 1px solid #ced4da;
    border-radius: 6px;
    font-size: 14px;
    transition: 0.3s;
}

.signup-container input:focus {
    border-color: #495057; /* 네이비톤 강조 */
    outline: none;
}

/* 제출 버튼 */
.signup-container button {
    width: 100%;
    padding: 12px;
    background-color: #495057; /* 게시판 글쓰기 버튼 톤과 통일 */
    color: #fff;
    border: none;
    border-radius: 6px;
    font-size: 16px;
    font-weight: 500;
    cursor: pointer;
    transition: 0.3s;
}

.signup-container button:hover {
    opacity: 0.85;
}

/* 하단 링크 */
.signup-container .login-link {
    margin-top: 15px;
    text-align: center;
    font-size: 14px;
}

.signup-container .login-link a {
    color: #495057; /* 네이비 톤 통일 */
    text-decoration: none;
    font-weight: 500;
}

.signup-container .login-link a:hover {
    text-decoration: underline;
}

</style>
</head>
<body>

<div class="signup-container">
    <h2>회원가입</h2>
    <form id="signupForm">
        <input type="text" id="id" name="id" placeholder="아이디" required>
        <input type="text" id="username" name="username" placeholder="이름" required>
        <input type="password" id="password" name="password" placeholder="비밀번호" required>
        <input type="password" id="passwordConfirm" name="passwordConfirm" placeholder="비밀번호 확인" required>
        <button type="button" onclick="signup()">회원가입</button>
    </form>
    <div class="login-link">
        이미 계정이 있으신가요? <a href="/loginPage">로그인</a>
    </div>
</div>

</body>
<script>
var xhr;
function getXHR(){
	if(window.ActiveXObject){
		return new ActiveXObject('Msxml2.XMLHTTP');
	}else if(window.XMLHttpRequest){
		return new XMLHttpRequest();
	}else{
		return null;
	}
}
function signup(){
	
    const id = document.getElementById("id").value;
    const username = document.getElementById("username").value;
    const password = document.getElementById("password").value;
    const passwordConfirm = document.getElementById("passwordConfirm").value;
    
    if(password !== passwordConfirm){
        alert("비밀번호가 일치하지 않습니다!");
        return;
    }
 
    const data = 'id='+id+'&username='+username+'&password='+password;


    xhr = getXHR();
    xhr.onreadystatechange=signupResult;
    xhr.open("POST", "/api/users/signup", true);
    xhr.setRequestHeader("Content-Type", "application/x-www-form-urlencoded");
    xhr.send(data);
}
function signupResult(){
	if(xhr.readyState==4){
		if(xhr.status==200){
			var data = xhr.responseText;
			window.alert(data);
		}
	}
}
</script>
</html>
<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>
<meta charset="UTF-8">
<title>게시판 목록</title>
<style>
/* 전체 초기화 */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: 'Arial', sans-serif;
    background-color: #f4f5f7;
    min-height: 100vh;
    color: #333;
}

/* 상단 헤더 */
.header {
    width: 100%;
    background-color: #ffffff;
    padding: 15px 50px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
}

.header h1 {
    font-size: 24px;
    font-weight: 600;
}

/* 로그인/회원가입 버튼 */
.header .auth-btns a {
    margin-left: 12px;
    padding: 8px 18px;
    border-radius: 6px;
    text-decoration: none;
    font-weight: 500;
    color: #fff;
    font-size: 14px;
    transition: 0.3s;
}

.header .auth-btns a.login {
    background-color: #495057; /* 네이비 그레이 톤 */
}

.header .auth-btns a.signup {
    background-color: #6c757d; /* 중간 회색 톤 */
}

.header .auth-btns a:hover {
    opacity: 0.85;
}

/* 컨테이너 */
.container {
    width: 90%;
    max-width: 1200px;
    margin: 40px auto;
    background-color: #fff;
    padding: 30px;
    border-radius: 12px;
    box-shadow: 0 5px 25px rgba(0,0,0,0.05);
}

/* 게시판 상단: 제목 + 글쓰기 버튼 */
.table-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
}

.table-header h2 {
    font-size: 22px;
    font-weight: 600;
}

/* 글쓰기 버튼 */
.write-btn {
    padding: 10px 25px;
    background-color: #495057; /* 네이비 톤 */
    color: white;
    text-decoration: none;
    border-radius: 6px;
    font-weight: 500;
    transition: 0.3s;
}

.write-btn:hover {
    opacity: 0.85;
}

/* 테이블 스타일 */
table {
    width: 100%;
    border-collapse: collapse;
}

th, td {
    padding: 12px;
    text-align: center;
    border-bottom: 1px solid #e0e0e0;
    word-break: break-word;
}

th {
    background-color: #343a40; /* 짙은 네이비 */
    color: #fff;
    font-weight: 500;
}

tr:nth-child(even) {
    background-color: #f8f9fa;
}

tr:hover {
    background-color: #e9ecef;
    cursor: pointer;
}

/* 제목 컬럼 왼쪽 정렬 */
th:nth-child(2), td:nth-child(2) {
    text-align: left;
    width: 50%;
}

/* 로그인 상태 환영 문구 */
.header .auth-btns .welcome {
    font-size: 14px;
    font-weight: 500;
    margin-right: 12px;
    color: #343a40; /* 짙은 네이비 톤 */
}

/* 로그아웃 버튼 */
.header .auth-btns .logout-btn {
    padding: 8px 18px;
    border-radius: 6px;
    text-decoration: none;
    font-weight: 500;
    color: #fff;
    font-size: 14px;
    background-color: #dc3545; /* 붉은 톤 로그아웃 버튼 */
    transition: 0.3s;
}

.header .auth-btns .logout-btn:hover {
    opacity: 0.85;
}
</style>
</head>
<body onload="boardList()">

<!-- 상단 헤더 -->
<div class="header">
    <h1>맑은준범</h1>
    <div class="auth-btns">
    	<div th:if="${session.id == null}">
    		<a href="/loginPage" class="login">로그인</a>
        	<a href="/signupPage" class="signup">회원가입</a>
    	</div>
    	<div th:if="${session.id != null}">
    		<span class="welcome">환영합니다, <strong th:text="${session.username}">사용자</strong>님!</span>
    		<a href="/logout" class="logout-btn">로그아웃</a>
    	</div>
    </div>
</div>

<!-- 게시판 컨테이너 -->
<div class="container">
    <!-- 상단 타이틀 + 글쓰기 버튼 -->
    <div class="table-header">
        <h2>게시판 목록</h2>
        <a href="/boardWrite" class="write-btn">글쓰기</a>
    </div>
    
    <!-- 게시판 테이블 -->
    <table>
        <thead>
            <tr>
                <th>번호</th>
                <th>제목</th>
                <th>작성자</th>
                <th>작성일</th>
                <th>조회수</th>
            </tr>
        </thead>
        <tfoot>
        	페이징 들어갈 영역
        </tfoot>
        <tbody id="boardBody">
        </tbody>
    </table>
</div>

</body>
<script>
	var xhr;
	function getXHR(){
		if(window.ActiveXObject){
			return new ActiveXObject('Msxml2.XMLHTTP');
		}else if(window.XMLHttpRequest){
			return new XMLHttpRequest();
		}else{
			return null;
		}
	}
	function boardList(cp=1){
		
		xhr = getXHR();
		xhr.onreadystatechange=boardListResult;
		xhr.open('GET', '/api/board/list?cp=' + cp, true);
		xhr.send(null);
		
	}
	function boardListResult(){
		if(xhr.readyState == 4){
			if(xhr.status == 200){
				var data = xhr.responseText;
				var boardList = JSON.parse(data);
				
				var tbody = document.getElementById('boardBody');
				tbody.innerHTML = '';
				
				for(let i = 0; i < boardList.length; i++){
					var board = boardList[i];
					var tr = document.createElement('tr');
					
					tr.innerHTML = 
				        '<td>' + board.board_idx + '</td>' +
				        '<td>' + board.title + '</td>' +
				        '<td>' + board.writer + '</td>' +
				        '<td>' + board.writedate.substring(0,10) + '</td>' +
				        '<td>' + board.readnum + '</td>';

				    // tbody에 추가
				    document.getElementById('boardBody').appendChild(tr);
				}
			
			}else{
				alert('게시판 데이터를 불러오지 못했습니다.');
			}
		}
	}
</script>
</html>
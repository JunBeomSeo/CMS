<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
  <mapper namespace="com.example.mapper.user.UserMapper">
  	<insert id="signup" parameterType="com.example.user.model.UserDTO">
  		INSERT INTO cms_user VALUES(user_idx_seq.nextval, #{id}, #{username}, #{password}, #{role})
  	</insert>
  	<select id="loginCheck" parameterType="String" resultType="com.example.user.model.UserDTO">
  		SELECT *
  		FROM cms_user
  		WHERE id=#{id} and password = #{password}
  	</select>
  	<select id="checkId" resultType="int">
		SELECT COUNT(*) FROM cms_user WHERE id = #{id}
	</select>
  </mapper>
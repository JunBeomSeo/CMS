<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>
<meta charset="UTF-8">
<title>맑은 준범 - 글쓰기</title>
<style>
    /* 전체 배경 */
    body {
        font-family: 'Arial', sans-serif;
        background-color: #f4f4f4;
        margin: 0;
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100vh;
    }

    /* 카드 스타일 */
    .card {
        background-color: #ffffff;
        border-radius: 12px;
        box-shadow: 0 6px 20px rgba(0,0,0,0.1);
        width: 520px;
        padding: 30px;
        display: flex;
        flex-direction: column;
    }

    /* 제목 */
    h2 {
        text-align: center;
        margin-top: 0;
        color: #222;
        font-size: 24px;
        margin-bottom: 20px;
    }

    /* 입력 필드 */
    input[type="text"], textarea {
        width: 100%;
        padding: 14px;
        margin-bottom: 20px;
        border-radius: 10px;
        border: 1px solid #ddd;
        font-size: 14px;
        font-family: inherit;
        box-sizing: border-box;
    }

    textarea {
        min-height: 180px;
        resize: vertical;
    }

    /* 버튼 그룹 */
    .btn-group {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
    }

    button {
        padding: 10px 22px;
        border-radius: 10px;
        font-size: 14px;
        cursor: pointer;
        border: none;
        font-family: inherit;
        transition: background-color 0.2s, color 0.2s;
    }

    /* 작성 버튼 */
    .btn-submit {
        background-color: #495057; /* 네이비 톤 */ 
        color: white;
        transition: 0.3s;
    }

    .btn-submit:hover {
		opacity: 0.85;
    }

    /* 취소 버튼 */
    .btn-cancel {
        background-color:#ccc;
        color: #000;
        transition: 0.3s;
    }

    .btn-cancel:hover {
		opacity: 0.85;
    }
</style>
</head>
<body>

<div class="card">
    <h2>게시글 작성</h2>

        <input type="text" name="title" placeholder="제목을 입력하세요" required>
        <textarea name="content" placeholder="내용을 입력하세요" required></textarea>

        <div class="btn-group">
            <button type="button" class="btn-cancel" onclick="window.history.back();">취소</button>
            <button type="button" class="btn-submit" onclick="write()">작성</button>
        </div>

</div>

</body>
<script>
	function write(){
		// 1. 입력값 가져오기
	    var title = document.getElementById("title").value;
	    var content = document.getElementById("content").value;

	    if (!title || !content) {
	        alert("제목과 내용을 모두 입력해주세요.");
	        return;
	    }

	    // 2. fetch로 POST 요청 보내기
	    fetch("/api/board", {
	        method: "POST",
	        headers: {
	            "Content-Type": "application/json"
	        },
	        body: JSON.stringify({ title: title, content: content })
	    })
	    .then(function(response) {
	        if (response.ok) {
	            alert("게시글이 작성되었습니다!");
	            window.location.href = "/boardList"; // 작성 후 목록 페이지로 이동
	        } else {
	            // 실패하면 서버에서 보내준 에러 메시지 확인
	            response.json().then(function(errorData) {
	                alert("오류 발생: " + (errorData.message || "알 수 없는 오류"));
	            });
	        }
	    })
	    .catch(function(err) {
	        console.error(err);
	        alert("서버와 통신 중 오류가 발생했습니다.");
	    });
	}
</script>
</html>
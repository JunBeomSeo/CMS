<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>
<meta charset="UTF-8">
<title>맑은 준범 - 글쓰기</title>
<style>
/* 전체 초기화 */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: 'Arial', sans-serif;
    background-color: #f4f5f7;
    min-height: 100vh;
    color: #333;
}
    /* 상단 헤더 */
.header {
    width: 100%;
    background-color: #ffffff;
    padding: 15px 50px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
}

.header h1 {
    font-size: 24px;
    font-weight: 600;
}

/* 로그인/회원가입 버튼 */
.header .auth-btns a {
    margin-left: 12px;
    padding: 8px 18px;
    border-radius: 6px;
    text-decoration: none;
    font-weight: 500;
    color: #fff;
    font-size: 14px;
    transition: 0.3s;
}

.header .auth-btns a.login {
    background-color: #495057;
}

.header .auth-btns a.signup {
    background-color: #6c757d;
}

.header .auth-btns a.logout-btn {
    background-color: #f03e3e;
}

.header .auth-btns a:hover {
    opacity: 0.85;
}

    /* 카드 스타일 */
    .card {
        background-color: #ffffff;
        border-radius: 12px;
        box-shadow: 0 6px 20px rgba(0,0,0,0.1);
        width: 520px;
        padding: 30px;
        display: flex;
        flex-direction: column;
        margin: 0 auto;
    }

    /* 제목 */
    h2 {
        text-align: center;
        margin-top: 0;
        color: #222;
        font-size: 24px;
        margin-bottom: 20px;
    }

    /* 입력 필드 */
    input[type="text"], textarea {
        width: 100%;
        padding: 14px;
        margin-bottom: 20px;
        border-radius: 10px;
        border: 1px solid #ddd;
        font-size: 14px;
        font-family: inherit;
        box-sizing: border-box;
    }

    textarea {
        min-height: 180px;
        resize: vertical;
    }

    /* 버튼 그룹 */
    .btn-group {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
    }

    button {
        padding: 10px 22px;
        border-radius: 10px;
        font-size: 14px;
        cursor: pointer;
        border: none;
        font-family: inherit;
        transition: background-color 0.2s, color 0.2s;
    }

    /* 작성 버튼 */
    .btn-submit {
        background-color: #495057; /* 네이비 톤 */ 
        color: white;
        transition: 0.3s;
    }

    .btn-submit:hover {
		opacity: 0.85;
    }

    /* 취소 버튼 */
    .btn-cancel {
        background-color:#ccc;
        color: #000;
        transition: 0.3s;
    }

    .btn-cancel:hover {
		opacity: 0.85;
    }
</style>
</head>
<body>
<!-- 상단 헤더 -->
<div class="header">
    <h1>맑은준범</h1>
    <div class="auth-btns">
    	<div th:if="${session.id == null}">
    		<a href="/loginPage" class="login">로그인</a>
        	<a href="/signupPage" class="signup">회원가입</a>
    	</div>
    	<div th:if="${session.id != null}">
		    <span class="welcome">
		        환영합니다,
		        <strong>
		            <span th:if="${session.role == 'ADMIN'}">관리자 </span>
		            <span th:text="${session.username}"></span>님!
		        </strong>
		    </span>
		    <a href="/logout" class="logout-btn">로그아웃</a>
    	</div>
    </div>
</div>

<div class="card">
    <h2>게시글 작성</h2>

        <input type="text" id="title" name="title" placeholder="제목을 입력하세요 (최대 20자)" maxlength="20" required>
        <textarea name="content" id="content" placeholder="내용을 입력하세요 (최대 150자)" maxlength="150" required></textarea>

        <div class="btn-group">
            <button type="button" class="btn-cancel" onclick="window.history.back();">취소</button>
            <button type="button" class="btn-submit" onclick="writeSubmit()">작성</button>
        </div>

</div>

</body>
<script>
	var xhr;
	function getXHR(){
		if(window.ActiveXObject){
			return new ActiveXObject('Msxml2.XMLHTTP');
		}else if(window.XMLHttpRequest){
			return new XMLHttpRequest();
		}else{
			return null;
		}
	}
	function writeSubmit(){
		 console.log("write 함수 호출됨");
		// 1. 입력값 가져오기
	    var title = document.getElementById("title").value;
	    var content = document.getElementById("content").value;

	    if (!title || !content) {
	        alert("제목과 내용을 모두 입력해주세요.");
	        return;
	    }
	    
	    var data = 'title=' + encodeURIComponent(title) + '&content=' + encodeURIComponent(content);
	    
	    xhr = getXHR();
	    xhr.onreadystatechange=writeResult;
	    xhr.open('POST', '/api/board/write', true);
	    xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
	    xhr.send(data);
	}
	function writeResult(){
		if(xhr.readyState == 4){
			var data = xhr.responseText;
			if(xhr.status == 200){
				window.alert(data);
				window.location.href='/boardList';
			}else if(xhr.status == 400){
				window.alert(data);
			}
		}
	}

</script>
</html>
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
  <mapper namespace="com.example.mapper.board.BoardMapper">
  	<insert id="boardWrite" parameterType="com.example.board.model.BoardDTO">
  		INSERT INTO cms_board VALUES(board_idx_seq.nextval, #{title}, #{content}, #{writer}, sysdate, #{modifier}, #{modifierdate}, #{readnum}, #{user_idx})
  	</insert>
  	<select id="boardList" parameterType="Map" resultType="com.example.board.model.BoardDTO">
  		SELECT *
  		FROM 
	  		(SELECT rownum as rnum, a.*
	  		 FROM
		  		(SELECT *
		  		 FROM cms_board
		  		 ORDER BY board_idx desc) a ) b
	    WHERE rnum BETWEEN #{dbStart} AND #{dbLast}
  	</select>
  	<select id="boardTotalCnt" resultType="Integer">
  		SELECT count(*)
  		FROM cms_board
  	</select>
  	<select id="boardContent" parameterType="Integer" resultType="com.example.board.model.BoardDTO">
  		SELECT *
  		FROM cms_board
  		WHERE board_idx = #{board_idx}
  	</select>
  	<update id="boardReadnum" parameterType="Integer">
  		UPDATE cms_board
  		SET readnum = #{readnum}
  		WHERE board_idx = #{board_idx} 
  	</update>
  </mapper>